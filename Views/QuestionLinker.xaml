<Window x:Class="JobTrackerWPF.Views.QuestionLinker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Link Question to Companies" Height="300" Width="400">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ListBox x:Name="LbCompanies" SelectionMode="Extended" />
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Save" Click="BtnSave_Click" Background="#1D9E75" Foreground="White"/>
            <Button Content="Cancel" Click="BtnCancel_Click" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
