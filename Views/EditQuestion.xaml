<Window x:Class="JobTrackerWPF.Views.EditQuestion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Question" Height="340" Width="600" WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Content="Question" Grid.Row="0"/>
        <TextBox x:Name="TxtQuestion" Grid.Row="1" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <Label Content="Round"/>
                <TextBox x:Name="TxtRound"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <Label Content="Rating (0-5)"/>
                <Slider x:Name="SldRating" Minimum="0" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True"/>
            </StackPanel>
        </Grid>

        <Label Content="Answer" Grid.Row="3" Margin="0,8,0,0"/>
        <TextBox x:Name="TxtAnswer" Grid.Row="4" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>

        <StackPanel Orientation="Horizontal" Grid.Row="5" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Label Content="Companies (comma-separated)" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="TxtCompanies" Width="240"/>
            <Button Content="Save" Click="BtnSave_Click" Margin="8,0,0,0" Background="#1D9E75" Foreground="White"/>
            <Button Content="Cancel" Click="BtnCancel_Click" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
